{
  "name": "@xhznezumi/molstar-structure-editor",
  "version": "0.1.0",
  "description": "Realtime structure editing extension package for Mol*",
  "type": "module",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --root .",
    "dev:example": "vite --config vite.config.ts --host 0.0.0.0 --port 4173",
    "preview:example": "vite preview --config vite.config.ts --host 0.0.0.0 --port 4173"
  },
  "peerDependencies": {
    "molstar": ">=5.6 <5.8"
  },
  "devDependencies": {
    "molstar": "^5.7.0",
    "typescript": "^5.9.3",
    "vite": "^7.1.3",
    "vitest": "^3.2.4"
  }
}
